
// Esquema de base de datos - Sistema de licencias SEG

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  EMPLEADO
  ADMIN
}

enum EstadoSolicitud {
  PENDIENTE
  APROBADA
  RECHAZADA
  CANCELADA
}

model Usuario {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  hash_contrasena  String
  rol              Rol       @default(EMPLEADO)
  esta_activo      Boolean   @default(true)
  fecha_creacion   DateTime  @default(now())
  fecha_actualizacion DateTime @updatedAt

  empleado         Empleado?
}

model Sector {
  id             Int        @id @default(autoincrement())
  nombre         String     @unique
  fecha_creacion DateTime   @default(now())

  empleados      Empleado[]
}

model Empleado {
  id             Int      @id @default(autoincrement())
  usuario_id     Int      @unique
  nombre         String
  apellido       String
  fecha_ingreso  DateTime
  es_encargado   Boolean  @default(false)
  esta_activo    Boolean  @default(true)
  sector_id      Int
  fecha_creacion    DateTime @default(now())
  fecha_actualizacion DateTime @updatedAt
  saldos SaldoLicencia[]

  usuario        Usuario  @relation(fields: [usuario_id], references: [id])
  sector         Sector   @relation(fields: [sector_id], references: [id])

  solicitudes  SolicitudLicencia[] @relation("solicitudes")
  revisiones   SolicitudLicencia[] @relation("revisiones")
}

model TipoLicencia {
  id             Int     @id @default(autoincrement())
  nombre         String  @unique
  codigo         String  @unique
  requiere_saldo Boolean @default(true)
  descripcion    String?
  esta_activo    Boolean @default(true)
  saldos SaldoLicencia[]

  solicitudes  SolicitudLicencia[]
}

model Feriado {
  id            Int      @id @default(autoincrement())
  fecha         DateTime @unique
  nombre        String
  es_recurrente Boolean  @default(false)
}

model SolicitudLicencia {
  id               Int       @id @default(autoincrement())
  empleado_id      Int
  tipo_licencia_id Int
  dias_descontados Int
  estado           EstadoSolicitud @default(PENDIENTE)
  comentario       String?
  revisado_por     Int?
  motivo_rechazo   String?
  fecha_creacion   DateTime  @default(now())

  empleado      Empleado      @relation("solicitudes", fields: [empleado_id], references: [id])
  revisor       Empleado?     @relation("revisiones", fields: [revisado_por], references: [id])
  tipo_licencia TipoLicencia  @relation(fields: [tipo_licencia_id], references: [id])
  dias          DiaSolicitado[]
}

model DiaSolicitado {
  id           Int      @id @default(autoincrement())
  solicitud_id Int
  fecha        DateTime

  solicitud    SolicitudLicencia @relation(fields: [solicitud_id], references: [id], onDelete: Cascade)
}

model SaldoLicencia {
  id              Int      @id @default(autoincrement())
  empleado_id     Int
  tipo_licencia_id Int
  anio            Int
  total_dias      Float
  dias_usados     Float    @default(0)
  dias_ajustados  Float    @default(0)

  empleado      Empleado     @relation(fields: [empleado_id], references: [id])
  tipo_licencia TipoLicencia @relation(fields: [tipo_licencia_id], references: [id])

  @@unique([empleado_id, tipo_licencia_id, anio])
}